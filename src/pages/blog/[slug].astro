---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const { slug } = Astro.params;
const post = await getEntry('blog', slug);

if (!post) {
  return Astro.redirect('/404');
}
---

<Layout title={post.data.title}>
  <section>
    <div class="container">
      <article class="post-detail">
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <time class="post-date">{post.data.pubDate.toLocaleDateString()}</time>
          {post.data.tags && (
            <div class="post-tags">
              {post.data.tags.map(tag => (
                <span class="tag" key={tag}>{tag}</span>
              ))}
            </div>
          )}
        </div>
        <div class="post-content" set:html={await post.render().Content} />
      </article>
    </div>
  </section>
</Layout>

<style>
  section {
    width: 100%;
    padding: 3rem 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .container {
    width: 75%;
  }

  .post-detail {
    background: #161616;
    border-radius: 10px;
    padding: 2.5rem;
    width: 100%;
    max-width: 800px;
  }

  .post-title {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    color: white;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .post-date {
    color: #facc25;
    font-size: 1.1rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    padding: 3px 8px;
    background-color: #242424;
    color: #facc25;
    border-radius: 5px;
    font-size: 0.9rem;
  }

  .post-content {
    color: #ccc;
    line-height: 1.8;
    font-size: 1.1rem;
  }

  .post-content h1,
  .post-content h2,
  .post-content h3 {
    color: white;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .post-content h1 {
    font-size: 2rem;
  }

  .post-content h2 {
    font-size: 1.75rem;
  }

  .post-content h3 {
    font-size: 1.5rem;
  }

  .post-content p {
    margin-bottom: 1.5rem;
  }

  .post-content a {
    color: #facc25;
    text-decoration: underline;
  }

  .post-content a:hover {
    text-decoration: none;
  }

  .post-content ul,
  .post-content ol {
    margin-left: 2rem;
    margin-bottom: 1.5rem;
  }

  .post-content blockquote {
    border-left: 4px solid #facc25;
    padding-left: 1.5rem;
    margin: 2rem 0;
    color: #aaa;
    font-style: italic;
  }

  .post-content pre {
    background-color: #000;
    padding: 1.5rem;
    border-radius: 5px;
    overflow-x: auto;
    margin: 2rem 0;
  }

  .post-content code {
    background-color: #242424;
    padding: 0.2rem 0.4rem;
    border-radius: 3px;
    font-family: 'Courier New', monospace;
  }

  @media (max-width: 767px) {
    .container {
      width: 90%;
    }
    
    .post-detail {
      padding: 1.5rem;
    }
    
    .post-title {
      font-size: 2rem;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .container {
      width: 90%;
    }
  }
</style>